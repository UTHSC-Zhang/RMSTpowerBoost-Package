# GitHub Actions workflow directory
^\.github$

# pkgdown configuration file
^_pkgdown\.yml$

# Other top-level files
^LICENSE\.md$
^README\.Rmd$
^pkgdown$


# The renv subdirectory
renv/

# Data Generation Script
^data-raw$

# top level directories
tools/
docs/


