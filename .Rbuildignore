^vignettes/.*_cache/
^vignettes/cache$
^vignettes/cache/
^vignettes/.*[.]html$
^vignettes/.*[.]R$
^vignettes/.*_files$
^vignettes/.*_files/
^.*_cache/
^.*[.]Rproj$
^\.Rproj\.user$
^\.github$
^\.vscode$
^renv$
^renv\.lock$
^tools$
^coverage$
^coverage\.html$
^codecov\.yml$
^lib$
